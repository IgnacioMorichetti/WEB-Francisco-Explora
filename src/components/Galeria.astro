---
const fotos = [
  { src: '/images/galeria-1.jpg', alt: 'Aventura 1' },
  { src: '/images/galeria-2.jpg', alt: 'Aventura 2' },
  { src: '/images/galeria-3.jpg', alt: 'Aventura 3' },
  { src: '/images/galeria-4.jpg', alt: 'Aventura 4' },
  { src: '/images/galeria-5.jpg', alt: 'Aventura 5' },
  { src: '/images/galeria-6.jpg', alt: 'Aventura 6' },
]
---

<section id="galeria" class="py-28 px-6 bg-[#FAF7F2]">
  <div class="max-w-6xl mx-auto">

    <div class="text-center mb-16">
      <p class="text-[#8B5E3C] text-sm uppercase tracking-[0.3em] mb-4">Galería</p>
      <h2 class="font-serif text-4xl md:text-5xl font-bold text-[#2C1A0E]">El camino en imágenes</h2>
      <div class="w-12 h-0.5 bg-[#4A7C59] mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {fotos.map((foto, i) => (
        <div class={`overflow-hidden bg-[#8B5E3C]/10 ${i === 0 ? 'col-span-2 row-span-2' : ''}`}>
          <img
            src={foto.src}
            alt={foto.alt}
            class="w-full h-full object-cover aspect-square hover:scale-105 transition-transform duration-500"
          />
        </div>
      ))}
    </div>

  </div>
</section>
