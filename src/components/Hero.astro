---
const WHATSAPP_GRUPO = 'https://chat.whatsapp.com/HSKTdjSCi443FdlIMSItGa?mode=gi_t'
// TODO: reemplazar por el WhatsApp personal de Francisco cuando lo pase.
const CONTACTO_MARCAS = 'mailto:aventureate@gmail.com?subject=Sos%20una%20marca%20-%20Francisco%20Explora'
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Foto de fondo -->
  <div class="absolute inset-0 bg-[url('/images/hero.jpg')] bg-cover bg-center opacity-60"></div>
  <!-- Veladura clara para legibilidad -->
  <div class="absolute inset-0 bg-gradient-to-b from-selva/80 via-selva/65 to-selva z-10"></div>

  <!-- Contenido -->
  <div class="relative z-20 text-center px-6 max-w-5xl mx-auto">
    <p class="text-musgo text-xs md:text-sm uppercase tracking-[0.4em] mb-6 font-semibold">
      El desafío de Francisco
    </p>
    <h1 class="font-serif text-6xl md:text-9xl font-black leading-none mb-6 uppercase tracking-tight text-crema">
      Explora
    </h1>

    <!-- Fecha y lugar destacados -->
    <p class="inline-block border-y border-tierra/40 py-3 px-2 text-tierra font-semibold tracking-[0.3em] uppercase text-sm md:text-base mb-8">
      28 · 06 · 2026 — Potrerillos, Mendoza
    </p>

    <p class="text-suave text-lg md:text-xl max-w-2xl mx-auto mb-3 leading-relaxed">
      Un triatlón personal: <span class="text-crema">1,9 km nadando, 90 km pedaleando y 21,1 km corriendo.</span>
    </p>
    <p class="text-crema text-xl md:text-2xl font-serif italic max-w-2xl mx-auto mb-12">
      Y la mejor parte: no lo corro solo.
    </p>

    <p class="text-crema text-base md:text-lg uppercase tracking-[0.3em] font-semibold mb-6">
      ¿Querés participar?
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={WHATSAPP_GRUPO}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-musgo text-selva px-10 py-4 text-sm uppercase tracking-widest font-black hover:bg-hoja transition-all duration-300"
      >
        Sumate al desafío
      </a>
      <a
        href={CONTACTO_MARCAS}
        class="inline-block border border-tierra text-crema px-10 py-4 text-sm uppercase tracking-widest font-black hover:bg-tierra/15 transition-all duration-300"
      >
        ¿Sos una marca?
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 text-suave/60">
    <span class="text-xs uppercase tracking-widest">Scroll</span>
    <div class="w-px h-12 bg-musgo/50 animate-pulse"></div>
  </div>
</section>
