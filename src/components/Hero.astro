---
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center bg-[#0a0a0a] overflow-hidden">
  <!-- Foto de fondo -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/30 via-transparent to-[#0a0a0a] z-10"></div>
  <div class="absolute inset-0 bg-[url('/images/hero.jpg')] bg-cover bg-center opacity-50"></div>

  <!-- Contenido -->
  <div class="relative z-20 text-center text-white px-6 max-w-5xl mx-auto">
    <p class="text-[#F97316] text-xs uppercase tracking-[0.5em] mb-8 font-sans font-semibold">
      Explorador · Atleta · Soñador
    </p>
    <h1 class="font-sans text-7xl md:text-[10rem] font-black leading-none mb-8 uppercase tracking-tight">
      Francisco<br />
      <span class="text-[#F97316]">Explora</span>
    </h1>
    <p class="text-white/60 text-lg md:text-xl max-w-xl mx-auto mb-12 font-light leading-relaxed">
      Cada aventura es una nueva página. Cada paso, una historia que contar.
    </p>
    <a
      href="#sobre-mi"
      class="inline-block bg-[#F97316] text-black px-10 py-4 text-sm uppercase tracking-widest font-black hover:bg-white transition-all duration-300"
    >
      Conocerme
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 text-white/30">
    <span class="text-xs uppercase tracking-widest">Scroll</span>
    <div class="w-px h-12 bg-[#F97316]/50 animate-pulse"></div>
  </div>
</section>
