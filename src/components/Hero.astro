---
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center bg-[#2C1A0E] overflow-hidden">
  <!-- Foto de fondo (reemplazar con foto real de Francisco) -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#2C1A0E]/40 via-[#2C1A0E]/20 to-[#2C1A0E]/80 z-10"></div>
  <div class="absolute inset-0 bg-[url('/images/hero.jpg')] bg-cover bg-center opacity-60"></div>

  <!-- Contenido -->
  <div class="relative z-20 text-center text-white px-6 max-w-4xl mx-auto">
    <p class="text-[#FAF7F2]/70 text-sm uppercase tracking-[0.3em] mb-6 font-sans">
      Explorador · Atleta · Soñador
    </p>
    <h1 class="font-serif text-6xl md:text-8xl font-black leading-tight mb-6">
      Francisco<br />
      <span class="text-[#8B5E3C]">Explora</span>
    </h1>
    <p class="text-[#FAF7F2]/80 text-lg md:text-xl max-w-xl mx-auto mb-10 font-light leading-relaxed">
      Cada aventura es una nueva página. Cada paso, una historia que contar.
    </p>
    <a
      href="#sobre-mi"
      class="inline-block border border-[#FAF7F2]/40 text-[#FAF7F2] px-8 py-3 text-sm uppercase tracking-widest hover:bg-[#FAF7F2] hover:text-[#2C1A0E] transition-all duration-300"
    >
      Conocerme
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 text-[#FAF7F2]/50">
    <span class="text-xs uppercase tracking-widest">Scroll</span>
    <div class="w-px h-12 bg-[#FAF7F2]/30 animate-pulse"></div>
  </div>
</section>
