---
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-selva/85 backdrop-blur-md border-b border-musgo/15">
  <div class="flex items-center justify-between px-6 md:px-8 py-4 max-w-7xl mx-auto">
    <a href="#inicio" class="font-serif text-lg md:text-xl font-black tracking-widest uppercase">
      Francisco <span class="text-musgo">Explora</span>
    </a>

    <!-- Menú desktop -->
    <ul class="hidden md:flex gap-8 text-sm font-semibold text-suave uppercase tracking-widest">
      <li><a href="#desafio" class="hover:text-musgo transition-colors">El desafío</a></li>
      <li><a href="#sobre-mi" class="hover:text-musgo transition-colors">Sobre mí</a></li>
      <li><a href="#galeria" class="hover:text-musgo transition-colors">Galería</a></li>
      <li><a href="#contacto" class="hover:text-musgo transition-colors">Contacto</a></li>
    </ul>

    <!-- Botón hamburguesa móvil -->
    <button
      id="menu-toggle"
      aria-label="Abrir menú"
      class="md:hidden flex flex-col gap-1.5 p-2"
    >
      <span class="block w-6 h-0.5 bg-crema transition-all"></span>
      <span class="block w-6 h-0.5 bg-crema transition-all"></span>
      <span class="block w-6 h-0.5 bg-crema transition-all"></span>
    </button>
  </div>

  <!-- Menú móvil desplegable -->
  <ul
    id="mobile-menu"
    class="hidden md:hidden flex-col gap-1 px-6 pb-6 pt-2 text-sm font-semibold text-suave uppercase tracking-widest border-t border-musgo/10"
  >
    <li><a href="#desafio" class="block py-3 hover:text-musgo transition-colors">El desafío</a></li>
    <li><a href="#sobre-mi" class="block py-3 hover:text-musgo transition-colors">Sobre mí</a></li>
    <li><a href="#galeria" class="block py-3 hover:text-musgo transition-colors">Galería</a></li>
    <li><a href="#contacto" class="block py-3 hover:text-musgo transition-colors">Contacto</a></li>
  </ul>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
    menu?.classList.toggle('flex')
  })

  // Cerrar el menú al tocar un link
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden')
      menu.classList.remove('flex')
    })
  })
</script>
