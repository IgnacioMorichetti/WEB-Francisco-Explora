---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Francisco Explora · Explorando la vida',
  description = 'Francisco Explora — explorador y soñador. El domingo 5 de julio de 2026 corre "Explora", un triatlón de larga distancia en Potrerillos. Sumate al desafío.'
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Aplica el modo oscuro antes del primer render para evitar el parpadeo.
         En /bocetos no aplica: cada boceto fuerza su propia paleta. -->
    <script is:inline>
      if (localStorage.getItem('tema') === 'oscuro' && !location.pathname.startsWith('/bocetos')) {
        document.documentElement.classList.add('dark')
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
